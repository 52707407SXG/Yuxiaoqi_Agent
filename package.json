  "type": "module",
  "main": "xiaoqi.mjs",
  "exports": {
    ".": "./xiaoqi.mjs"
  },
  "scripts": {
    "start": "node xiaoqi.mjs serve",
    "xiaoqi": "node --import tsx xiaoqi/src/cli.ts",
    "xiaoqi:serve": "node --import tsx xiaoqi/src/cli.ts serve",
    "xiaoqi:test": "node --import tsx --test xiaoqi/tests/*.test.ts",
    "xiaoqi:scan:brand": "node scripts/xiaoqi-brand-scan.mjs",
    "xiaoqi:scan:secrets": "node scripts/xiaoqi-secret-scan.mjs",
    "xiaoqi:verify": "node --import tsx --test xiaoqi/tests/*.test.ts && node scripts/xiaoqi-brand-scan.mjs && node scripts/xiaoqi-secret-scan.mjs"
  },
